{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@moneypulse/core": ["packages/core/src/index.ts"],
      "@moneypulse/ui": ["packages/ui/src/index.ts"],
      "@moneypulse/ui/styles.css": ["packages/ui/src/styles.css"]
    }
  }
}

